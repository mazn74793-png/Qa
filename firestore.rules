rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "motaem23y@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'fullName', 'role', 'email']) &&
             data.uid == request.auth.uid &&
             data.fullName is string && data.fullName.size() <= 100 &&
             data.role in ['student', 'parent', 'teacher', 'admin'] &&
             data.email is string && data.email.size() <= 100 &&
             (data.phone == null || (data.phone is string && data.phone.size() <= 20));
    }

    function isValidCourse(data) {
      return data.keys().hasAll(['name', 'teacherName', 'gradeLevel', 'price']) &&
             data.name is string && data.name.size() <= 150 &&
             data.teacherName is string && data.teacherName.size() <= 100 &&
             data.price is number && data.price >= 0;
    }

    function isValidExam(data) {
      return data.keys().hasAll(['title', 'teacherName', 'questions', 'createdAt']) &&
             data.title is string && data.title.size() <= 250 &&
             data.teacherName is string &&
             data.questions is list &&
             (data.solutionVideoUrl == null || data.solutionVideoUrl is string) &&
             data.createdAt == request.time;
    }

    function isValidSubmission(data) {
      return data.keys().hasAll(['examId', 'studentId', 'answers', 'submittedAt']) &&
             data.studentId == request.auth.uid &&
             data.examId is string &&
             data.answers is map &&
             data.submittedAt == request.time;
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['studentId', 'slotId', 'createdAt']) &&
             data.studentId == request.auth.uid &&
             data.slotId is string &&
             data.createdAt == request.time;
    }

    // --- Rules ---

    // Deny all by default at the end of the block (moved for clarity)
    
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'phone', 'gradeLevel', 'parentId']);
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /exams/{examId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (resource.data.active == true || isAdmin());
      allow create: if isAdmin() && isValidExam(incoming());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /submissions/{submissionId} {
      allow get: if isSignedIn() && (isOwner(existing().studentId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidSubmission(incoming());
      allow update: if false;
    }

    match /bookings/{bookingId} {
      allow get: if isSignedIn() && (isOwner(existing().studentId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidBooking(incoming());
      allow delete: if isSignedIn() && (isOwner(existing().studentId) || isAdmin());
    }

    match /teachers/{teacherId} {
      allow read: if true; // Teachers are public
      allow write: if isAdmin();
    }

    match /schedule/{slotId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /attendance/{recordId} {
      allow read: if isSignedIn() && (isOwner(existing().studentId) || isAdmin());
      allow create: if isAdmin();
      allow update: if isAdmin();
    }

    match /grades/{gradeId} {
      allow read: if isSignedIn() && (isOwner(existing().studentId) || isAdmin());
      allow write: if isAdmin();
    }

    match /materials/{materialId} {
      allow read: if isSignedIn(); // Logged in students can see materials
      allow write: if isAdmin();
    }

    match /videos/{videoId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true; // Public settings (hero text, etc.)
      allow write: if isAdmin();
    }
    
    // Admins collection - managed by admins
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin(); 
    }
  }
}
