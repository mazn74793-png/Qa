rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "motaem23y@gmail.com"
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'fullName', 'role', 'email']) &&
             data.keys().size() <= 8 &&
             data.uid == request.auth.uid &&
             data.fullName is string && data.fullName.size() <= 100 &&
             data.role in ['student', 'parent', 'teacher', 'admin'] &&
             data.email is string && data.email.size() <= 100;
    }

    function isValidCourse(data) {
      return data.keys().hasAll(['name', 'teacherName', 'gradeLevel', 'price']) &&
             data.name is string && data.name.size() <= 100 &&
             data.teacherName is string && data.teacherName.size() <= 100 &&
             data.gradeLevel is string && data.gradeLevel.size() <= 50 &&
             data.price is number && data.price >= 0;
    }

    // --- Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin(); // Only admins can list all users
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'phone', 'gradeLevel', 'parentId']);
    }

    match /courses/{courseId} {
      allow read: if true; // Courses are public for browsing
      allow write: if isAdmin();
    }

    match /teachers/{teacherId} {
      allow read: if true; // Teachers are public
      allow write: if isAdmin();
    }

    match /schedule/{slotId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /attendance/{recordId} {
      allow read: if isSignedIn() && (isOwner(existing().studentId) || isAdmin());
      allow create: if isAdmin();
      allow update: if isAdmin();
    }

    match /grades/{gradeId} {
      allow read: if isSignedIn() && (isOwner(existing().studentId) || isAdmin());
      allow write: if isAdmin();
    }

    match /materials/{materialId} {
      allow read: if isSignedIn(); // Logged in students can see materials
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true; // Public settings (hero text, etc.)
      allow write: if isAdmin();
    }
    
    // Admins collection - managed by admins
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin(); 
    }
  }
}
