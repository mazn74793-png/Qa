rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net - Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Auth tokens never contain custom claims in this environment.
    // We must look up the role from the 'users' collection.
    // NOTE: get() is used for RBAC lookups.
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "motaem23y@gmail.com" ||
        request.auth.token.email.matches('.*@qa\\.com$') ||
        getUserData().get('role', 'user') == 'admin' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['fullName', 'role', 'email']) &&
             data.fullName is string && data.fullName.size() <= 100 &&
             data.get('role', 'student') in ['student', 'parent', 'teacher', 'admin'] &&
             data.email is string && data.email.size() <= 100 &&
             (data.get('avatarUrl', null) == null || (data.avatarUrl is string && data.avatarUrl.size() <= 500));
    }

    function isValidCourse(data) {
      return data.keys().hasAll(['name', 'teacher', 'grade']) &&
             data.name is string && data.name.size() <= 200 &&
             data.teacher is string && data.teacher.size() <= 100;
    }

    function isValidExam(data) {
      return data.keys().hasAll(['title', 'teacherName', 'questions', 'createdAt']) &&
             data.title is string && data.title.size() <= 255 &&
             data.questions is list && data.questions.size() <= 100;
    }

    function isValidMaterial(data) {
      return data.keys().hasAll(['title', 'teacherId', 'url']) &&
             data.title is string && data.title.size() <= 200 &&
             isValidId(data.teacherId) &&
             data.url is string && data.url.size() <= 500;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && (
        // Allow updating everything EXCEPT role for self
        incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'phone', 'gradeLevel', 'parentId', 'avatarUrl', 'lastLogin']) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /schedule/{slotId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /teachers/{teacherId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /materials/{materialId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /videos/{videoId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /exams/{examId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (resource.data.get('active', false) == true || isAdmin());
      allow write: if isAdmin();
    }

    match /submissions/{submissionId} {
      allow get: if isSignedIn() && (isOwner(existing().studentId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().studentId == request.auth.uid;
    }

    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (isOwner(resource.data.studentId) || isAdmin());
      allow create: if isSignedIn() && incoming().studentId == request.auth.uid;
      allow delete: if isAdmin() || (isSignedIn() && isOwner(resource.data.studentId));
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admins/{adminId} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin();
    }

  }
}
